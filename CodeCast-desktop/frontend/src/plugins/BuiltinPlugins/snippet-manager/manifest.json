{"id": "snippet-manager", "name": "Snippet Manager", "version": "1.0.0", "description": "强大的代码片段管理系统，支持创建、分类、搜索和快速插入常用代码模板。支持多语言、标签系统和云同步。", "author": "CodeCast Team", "license": "MIT", "homepage": "https://github.com/codecast/plugins/snippet-manager", "repository": {"type": "git", "url": "https://github.com/codecast/plugins/snippet-manager.git"}, "keywords": ["snippets", "code-templates", "productivity", "code-reuse"], "category": "development", "entry": "./index.ts", "permissions": ["storage:read", "storage:write", "clipboard:read", "clipboard:write"], "configSchema": {"type": "object", "properties": {"maxSnippets": {"type": "number", "minimum": 10, "maximum": 10000, "default": 1000, "description": "最大片段数量"}, "autoBackup": {"type": "boolean", "default": true, "description": "自动备份片段到文件"}, "backupInterval": {"type": "number", "minimum": 60, "maximum": 86400, "default": 3600, "description": "备份间隔（秒）"}, "enableSync": {"type": "boolean", "default": false, "description": "启用云端同步"}, "defaultLanguage": {"type": "string", "default": "typescript", "description": "默认编程语言"}}, "required": []}, "features": {"snippets": {"create": true, "edit": true, "delete": true, "search": true, "tagging": true, "categorization": true, "export": true, "import": true}, "templates": {"builtin": 20, "custom": "unlimited", "variables": true, "placeholders": true}}, "dependencies": {}, "peerDependencies": {}, "ui": {"sidebarPanel": "./components/SnippetSidebar.tsx", "quickPick": {"command": "snippet.insert", "icon": "📋", "label": "Insert Snippet"}}}