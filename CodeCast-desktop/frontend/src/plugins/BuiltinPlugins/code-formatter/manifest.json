{"id": "code-formatter", "name": "Code Formatter", "version": "1.0.0", "description": "自动格式化代码，支持多种编程语言和自定义规则。集成 Prettier、ESLint 等工具。", "author": "CodeCast Team", "license": "MIT", "homepage": "https://github.com/codecast/plugins/code-formatter", "repository": {"type": "git", "url": "https://github.com/codecast/plugins/code-formatter.git"}, "keywords": ["formatting", "prettier", "eslint", "code-quality", "auto-format"], "category": "development", "entry": "./index.ts", "permissions": ["file:read", "file:write"], "configSchema": {"type": "object", "properties": {"language": {"type": "string", "enum": ["typescript", "javascript", "python", "go", "rust", "java"], "default": "typescript", "description": "目标语言"}, "tabWidth": {"type": "number", "minimum": 2, "maximum": 8, "default": 2, "description": "缩进宽度"}, "useSemicolons": {"type": "boolean", "default": true, "description": "使用分号"}, "singleQuote": {"type": "boolean", "default": false, "description": "使用单引号"}, "trailingComma": {"type": "string", "enum": ["all", "es5", "none"], "default": "all", "description": "尾随逗号"}, "printWidth": {"type": "number", "minimum": 40, "maximum": 200, "default": 80, "description": "行宽限制"}, "autoFormatOnSave": {"type": "boolean", "default": true, "description": "保存时自动格式化"}}, "required": ["language"]}, "features": {"formatter": {"languages": ["typescript", "javascript", "tsx", "jsx", "python", "go", "rust", "java", "json", "yaml", "markdown"], "configurable": true, "supportsRangeFormatting": true}, "linter": {"integrations": ["eslint", "stylelint", "pylint", "golangci-lint"]}}, "dependencies": {}, "peerDependencies": {}, "scripts": {"format": "node ./dist/format.js", "lint": "node ./dist/lint.js"}, "ui": {"settingsPanel": "./components/SettingsPanel.tsx", "toolbarButton": {"icon": "✨", "label": "Format Code", "tooltip": "Format current file or selection"}}}