{"id": "github-integration", "name": "GitHub Integration", "version": "1.0.0", "description": "无缝集成 GitHub 功能，包括仓库管理、Issue 跟踪、PR 创建、代码审查和 CI/CD 状态监控。", "author": "CodeCast Team", "license": "MIT", "homepage": "https://github.com/codecast/plugins/github-integration", "repository": {"type": "git", "url": "https://github.com/codecast/plugins/github-integration.git"}, "keywords": ["github", "git", "version-control", "ci-cd", "collaboration"], "category": "integration", "entry": "./index.ts", "permissions": ["network:fetch", "file:read", "clipboard:read", "clipboard:write"], "configSchema": {"type": "object", "properties": {"token": {"type": "string", "description": "GitHub Personal Access Token"}, "defaultOwner": {"type": "string", "description": "默认仓库所有者/组织"}, "defaultRepo": {"type": "string", "description": "默认仓库名称"}, "autoSyncInterval": {"type": "number", "minimum": 60, "maximum": 3600, "default": 300, "description": "自动同步间隔（秒）"}, "showNotifications": {"type": "boolean", "default": true, "description": "显示 GitHub 通知"}, "enablePRReviews": {"type": "boolean", "default": true, "description": "启用 PR 审查功能"}}, "required": ["token"]}, "features": {"repository": {"browse": true, "create": true, "fork": true, "clone": true}, "issues": {"list": true, "create": true, "update": true, "close": true, "labels": true, "milestones": true}, "pullRequests": {"list": true, "create": true, "review": true, "merge": true, "comments": true}, "actions": {"status": true, "workflows": true, "runs": true}}, "dependencies": {}, "peerDependencies": {}, "ui": {"sidebarPanel": "./components/GitHubSidebar.tsx", "statusBarItems": [{"id": "github-issues", "icon": "🐛", "tooltip": "Open Issues", "onClick": "command:github.show-issues"}, {"id": "github-prs", "icon": "🔀", "tooltip": "Pull Requests", "onClick": "command:github.show-prs"}, {"id": "github-ci", "icon": "✅", "tooltip": "CI/CD Status", "onClick": "command:github.show-ci-status"}]}}